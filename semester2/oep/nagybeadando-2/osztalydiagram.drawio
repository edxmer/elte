        <mxCell id="6iYGNVwnziPoldUdajlp-163" parent="1" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Lovag.Cselekvés():void&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;if Meghalt() then error endif&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;if Sérült() &amp;amp;&amp;amp; !(Hely() is KirályiTartomány) then&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;KirályiTartománybaVisszatér()&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;end&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;else if Sérült() &amp;amp;&amp;amp; Hely() is KirályiTaromány then&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Gyógyul()&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;end&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;else if this is BátorLovag &amp;amp;&amp;amp; Hely() is EllenségesTartomány then&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Harcol()&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if Hely().Halott() then Hely().Semlegesít() endif&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;end&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;else&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;KövetkezőTartomány()&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if Hely() is SemlegesTartomány &amp;amp;&amp;amp; (this is BátorLovag || this is VakmerőLovag) then&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Hely().TartományElfoglalása()&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;else if Hely() is EllenségesTartomány then&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Harcol()&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if Hely().Halott() then Hely().Semlegesít() endif&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;end&lt;/p&gt;" vertex="1">
          <mxGeometry height="430" width="495" x="2010" y="-90" as="geometry" />
