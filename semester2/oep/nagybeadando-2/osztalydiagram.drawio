        <mxCell id="6iYGNVwnziPoldUdajlp-135" parent="1" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Királyság.Királyság(ls:Lovag*, t:sTartomány*)&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;if t.Length = 0 then error endif&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;lovagIdx := 0&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;lovagok := new List&amp;lt;Lovag&amp;gt;()&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;tartományok := new List&amp;lt;Tartomány&amp;gt;()&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;foreach l in ls do&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if l is ÓvatosLovag then&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;lovagok.Add(new ÓvatosLovag(l.név, this))&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;else if l is BátorLovag then&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;lovagok.Add(new BátorLovag(l.név, this))&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;else&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;lovagok.Add(new VakmerőLovag(l.név, this))&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;élőLovagokSzáma += 1&lt;/span&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;done&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;i:=0&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;foreach t in ts do&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;if t is KirályiTartomány then&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;tartományok.Add(new KirályiTartomány(t.név, this, i) )&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;else if t is EllenségesTartomány then&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;tartományok.Add(new EllenségesTartomány(t.név, this, i) )&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;else&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;tartományok.Add(new SemlegesTartomány(t.név, this, i) )&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;end&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;i += 1&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;end&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;if !(tartományok[0] is KirályiTartomány) then error endif&lt;/p&gt;" vertex="1">
