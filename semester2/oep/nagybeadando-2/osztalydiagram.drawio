        <mxCell id="6iYGNVwnziPoldUdajlp-165" parent="1" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Lovag.KövetkezőTartomány():void&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin: 4px 0px 0px; padding-left: 5px;&quot;&gt;helyIdx := (helyIdx + 1) % királyság.tartományok.Length&lt;/p&gt;" vertex="1">
